# ── Frontend (FE) Exclusions ──
FE/node_modules/
FE/dist/
FE/dist-ssr/
FE/*.local

# ── Backend Exclusions ──
Backend/venv/
Backend/ENV/
Backend/env/
Backend/.venv/
Backend/.env
Backend/.env.*
Backend/__pycache__/
Backend/*.pyc
Backend/*.pyo
Backend/*.pyd
Backend/.pytest_cache/

# ── Global logs & system files ──
.vscode/
.idea/
*.suo
.DS_Store
*.log
logs/
